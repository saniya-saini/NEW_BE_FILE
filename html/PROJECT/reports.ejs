<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Submitted Reports - TrackBus</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
        }

        body {
            background: #f3f4f6;
            padding: 40px 20px;
        }

        .page-wrapper {
            max-width: 900px;
            margin: 0 auto;
        }

        h1 {
            color: #667eea;
            text-align: center;
            font-size: 32px;
            margin-bottom: 10px;
        }

        .subtitle {
            text-align: center;
            color: #555;
            margin-bottom: 30px;
            font-size: 15px;
        }

        .back-link {
            display: inline-block;
            margin-bottom: 25px;
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
            font-size: 15px;
        }

        .back-link:hover {
            text-decoration: underline;
        }

        .no-reports {
            text-align: center;
            color: #999;
            padding: 60px 40px;
            background: white;
            border-radius: 12px;
            border: 2px dashed #e5e7eb;
            font-size: 16px;
        }

        .report-card {
            background: white;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .severity-high {
            border-left: 6px solid #ef4444;
            background: #fff8f8;
        }

        .severity-medium {
            border-left: 6px solid #f59e0b;
            background: #fffdf0;
        }

        .severity-low {
            border-left: 6px solid #10b981;
            background: #f0fdf9;
        }

        .report-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 12px;
            border-bottom: 1px solid #f3f4f6;
        }

        .report-type {
            font-size: 20px;
            font-weight: bold;
            color: #1f2937;
        }

        .badge {
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .badge-high {
            background: #fee2e2;
            color: #991b1b;
        }

        .badge-medium {
            background: #fed7aa;
            color: #92400e;
        }

        .badge-low {
            background: #d1fae5;
            color: #065f46;
        }

        .report-body p {
            margin: 8px 0;
            color: #4b5563;
            font-size: 14px;
            line-height: 1.6;
        }

        .report-body p strong {
            color: #374151;
            min-width: 120px;
            display: inline-block;
        }

        .report-timestamp {
            margin-top: 12px;
            padding-top: 10px;
            border-top: 1px solid #f3f4f6;
            color: #9ca3af;
            font-size: 12px;
        }

        .footer-link {
            text-align: center;
            margin-top: 40px;
        }

        .footer-link a {
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
        }

        .footer-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="page-wrapper">

        <h1>📋 All Submitted Reports</h1>
        <p class="subtitle">Total Reports: <%= reports.length %></p>

        <a href="/reporting.html" class="back-link">← Back to Report Form</a>

        <% if (reports.length === 0) { %>

            <div class="no-reports">
                No reports submitted yet.
            </div>

        <% } else { %>

            <% reports.forEach(function(report) { %>

                <div class="report-card severity-<%= report.severity %>">

                    <div class="report-header">
                        <span class="report-type"><%= report.reportType %></span>
                        <span class="badge badge-<%= report.severity %>">
                            <%= report.severity %>
                        </span>
                    </div>

                    <div class="report-body">
                        <p><strong>Bus Number:</strong> <%= report.busNumber %></p>
                        <p><strong>Location:</strong> <%= report.location %></p>
                        <p><strong>Date:</strong> <%= report.date %></p>
                        <p><strong>Time:</strong> <%= report.time %></p>
                        <p><strong>Description:</strong> <%= report.description %></p>
                        <p><strong>Submitted By:</strong> <%= report.submittedBy %></p>
                        <p><strong>Rating:</strong> <%= report.rating %> / 5</p>
                    </div>

                    <div class="report-timestamp">
                        Submitted on: <%= new Date(report.createdAt).toLocaleString() %>
                    </div>

                </div>

            <% }); %>

        <% } %>

        <div class="footer-link">
            <a href="/reporting.html">← Back to Report Form</a>
        </div>

    </div>

</body>
</html>